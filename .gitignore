# ============================================================
# VoiceTrace .gitignore
# ============================================================

# Environment and secrets
.env
.env.local
.env.*.local
*.pem
credentials.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
ENV/
env/
.conda/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# IDEs
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data (large files)
data/raw/
data/synthetic/audio/
*.wav
*.mp3
*.geojson

# Temporary files
*.log
*.tmp
*.temp
.DS_Store
Thumbs.db

# Project-specific caches
.project-planner/
.claude/

# Downloaded/generated large files
*.zip
*.tar.gz
dhs.pdf

# Results (regenerable)
# Uncomment if you want to track results:
# results/

# Paper outputs (regenerable)
paper/*.pdf
paper/*.aux
paper/*.log
paper/*.out
paper/*.bbl
paper/*.blg
paper/*.fls
paper/*.fdb_latexmk
paper/*.synctex.gz

# Shared/handoff directories (duplicates)
shared/teammate_handoff/

# Internal commit assignments (not for repo)
commit_assignments/
